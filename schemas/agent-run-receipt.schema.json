{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/agent-run-receipt.schema.json",
  "title": "Agent Run Receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "receipt_id",
    "title",
    "date",
    "agent_type",
    "task_summary",
    "boundaries",
    "changed_files",
    "verification",
    "human_gate",
    "public_action_taken",
    "notes"
  ],
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "minLength": 1 },
    "agent_type": { "type": "string", "minLength": 1 },
    "task_summary": { "type": "string", "minLength": 1 },
    "boundaries": { "type": "array", "items": { "type": "string" } },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "array", "items": { "type": "string" } },
    "human_gate": {
      "type": "object",
      "required": ["status", "approval_note"],
      "properties": {
        "status": { "type": "string" },
        "approval_note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "public_action_taken": { "type": "boolean" },
    "notes": { "type": "string" },
    "development_delta": {
      "type": "object",
      "description": "Optional development-delta extension for agent work that claims concrete progress.",
      "required": [
        "changed_artifacts",
        "capability_delta",
        "validation_evidence",
        "next_blocker_or_artifact",
        "non_actions_preserved"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["development_delta", "blocked_with_evidence", "not_a_delta"]
        },
        "changed_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "capability_delta": { "type": "string", "minLength": 10 },
        "validation_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_blocker_or_artifact": { "type": "string", "minLength": 10 },
        "non_actions_preserved": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    }
  }
}

